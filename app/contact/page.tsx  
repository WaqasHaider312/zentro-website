"use client"

import { useState } from "react"
import Link from "next/link"
import { Navbar } from "@/components/navbar"
import { Footer } from "@/components/footer"
import { Button } from "@/components/ui/button"
import { ArrowRight, MessageSquare, Mail, Phone, CheckCircle, Loader2 } from "lucide-react"

const TEAM_SIZES = ["1–3 agents", "4–10 agents", "11–25 agents", "25+ agents"]
const CHANNELS = ["WhatsApp", "Instagram", "Facebook Messenger", "Web Chat", "All of the above"]

export default function ContactPage() {
  const [form, setForm] = useState({
    name: "",
    email: "",
    company: "",
    teamSize: "",
    channel: "",
    message: "",
  })
  const [submitting, setSubmitting] = useState(false)
  const [submitted, setSubmitted] = useState(false)
  const [error, setError] = useState("")

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault()
    if (!form.name || !form.email || !form.message) {
      setError("Please fill in your name, email, and message.")
      return
    }
    setError("")
    setSubmitting(true)

    try {
      // Send to Formspree or similar — replace with your endpoint
      const res = await fetch("https://formspree.io/f/YOUR_FORM_ID", {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(form),
      })
      if (res.ok) {
        setSubmitted(true)
      } else {
        setError("Something went wrong. Please email us directly at hello@zentrodesk.com")
      }
    } catch {
      setError("Something went wrong. Please email us directly at hello@zentrodesk.com")
    } finally {
      setSubmitting(false)
    }
  }

  return (
    <div className="flex min-h-screen flex-col">
      <Navbar />
      <main className="flex-1">

        {/* Header */}
        <section className="px-6 py-20 md:py-28">
          <div className="mx-auto max-w-7xl">
            <div className="mx-auto mb-16 max-w-2xl text-center">
              <p className="mb-3 text-sm font-semibold uppercase tracking-wider text-primary">
                Talk to Sales
              </p>
              <h1 className="font-display text-4xl font-bold tracking-tight text-foreground md:text-5xl text-balance">
                Let's find the right plan for your team
              </h1>
              <p className="mt-4 text-lg leading-relaxed text-muted-foreground">
                Tell us about your business and we'll help you get started — or just{" "}
                <Link href="https://zentrodesk.com/signup" className="text-primary font-semibold hover:underline">
                  sign up directly
                </Link>{" "}
                for a free trial.
              </p>
            </div>

            <div className="mx-auto grid max-w-5xl grid-cols-1 gap-12 lg:grid-cols-5">

              {/* Left — Contact info */}
              <div className="lg:col-span-2 space-y-8">
                <div>
                  <h2 className="font-semibold text-foreground mb-4">Why teams choose Zentro Desk</h2>
                  <ul className="space-y-3">
                    {[
                      "WhatsApp, Instagram, Messenger & web chat unified",
                      "AI handles up to 80% of queries automatically",
                      "Auto-assign rules so no ticket is missed",
                      "Setup in under 5 minutes",
                      "Built for Pakistan & emerging markets",
                    ].map((item) => (
                      <li key={item} className="flex items-start gap-2.5 text-sm text-muted-foreground">
                        <CheckCircle className="h-4 w-4 text-primary flex-shrink-0 mt-0.5" />
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>

                <div className="rounded-2xl border border-border bg-card p-6 space-y-4">
                  <p className="font-semibold text-foreground text-sm">Prefer to reach out directly?</p>
                  <a href="mailto:hello@zentrodesk.com" className="flex items-center gap-2.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
                    <Mail className="h-4 w-4 text-primary" />
                    hello@zentrodesk.com
                  </a>
                  <a href="https://wa.me/923075958033" target="_blank" rel="noopener noreferrer" className="flex items-center gap-2.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
                    <Phone className="h-4 w-4 text-primary" />
                    WhatsApp us
                  </a>
                  <a href="https://zentrodesk.com/signup" className="flex items-center gap-2.5 text-sm text-muted-foreground hover:text-foreground transition-colors">
                    <MessageSquare className="h-4 w-4 text-primary" />
                    Start free trial directly
                  </a>
                </div>
              </div>

              {/* Right — Form */}
              <div className="lg:col-span-3">
                {submitted ? (
                  <div className="flex flex-col items-center justify-center h-full py-16 text-center rounded-2xl border border-border bg-card px-8">
                    <div className="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center mb-4">
                      <CheckCircle className="h-8 w-8 text-primary" />
                    </div>
                    <h3 className="text-xl font-bold text-foreground mb-2">We'll be in touch soon!</h3>
                    <p className="text-muted-foreground mb-6">
                      Thanks for reaching out. We typically respond within a few hours.
                    </p>
                    <Button asChild>
                      <Link href="https://zentrodesk.com/signup">
                        Start Free Trial Now
                        <ArrowRight className="ml-2 h-4 w-4" />
                      </Link>
                    </Button>
                  </div>
                ) : (
                  <form onSubmit={handleSubmit} className="rounded-2xl border border-border bg-card p-8 space-y-5">
                    <div className="grid grid-cols-1 gap-5 sm:grid-cols-2">
                      <div>
                        <label className="block text-sm font-semibold text-foreground mb-1.5">
                          Full Name <span className="text-destructive">*</span>
                        </label>
                        <input
                          type="text"
                          value={form.name}
                          onChange={e => setForm(f => ({ ...f, name: e.target.value }))}
                          placeholder="Your name"
                          className="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                        />
                      </div>
                      <div>
                        <label className="block text-sm font-semibold text-foreground mb-1.5">
                          Work Email <span className="text-destructive">*</span>
                        </label>
                        <input
                          type="email"
                          value={form.email}
                          onChange={e => setForm(f => ({ ...f, email: e.target.value }))}
                          placeholder="you@company.com"
                          className="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                        />
                      </div>
                    </div>

                    <div>
                      <label className="block text-sm font-semibold text-foreground mb-1.5">Company / Store Name</label>
                      <input
                        type="text"
                        value={form.company}
                        onChange={e => setForm(f => ({ ...f, company: e.target.value }))}
                        placeholder="Your business name"
                        className="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                      />
                    </div>

                    <div className="grid grid-cols-1 gap-5 sm:grid-cols-2">
                      <div>
                        <label className="block text-sm font-semibold text-foreground mb-1.5">Team Size</label>
                        <select
                          value={form.teamSize}
                          onChange={e => setForm(f => ({ ...f, teamSize: e.target.value }))}
                          className="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                        >
                          <option value="">Select...</option>
                          {TEAM_SIZES.map(s => <option key={s} value={s}>{s}</option>)}
                        </select>
                      </div>
                      <div>
                        <label className="block text-sm font-semibold text-foreground mb-1.5">Primary Channel</label>
                        <select
                          value={form.channel}
                          onChange={e => setForm(f => ({ ...f, channel: e.target.value }))}
                          className="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                        >
                          <option value="">Select...</option>
                          {CHANNELS.map(c => <option key={c} value={c}>{c}</option>)}
                        </select>
                      </div>
                    </div>

                    <div>
                      <label className="block text-sm font-semibold text-foreground mb-1.5">
                        What can we help you with? <span className="text-destructive">*</span>
                      </label>
                      <textarea
                        value={form.message}
                        onChange={e => setForm(f => ({ ...f, message: e.target.value }))}
                        rows={4}
                        placeholder="Tell us about your support setup, how many messages you handle, or any questions..."
                        className="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-none"
                      />
                    </div>

                    {error && (
                      <p className="text-sm text-destructive">{error}</p>
                    )}

                    <Button
                      type="submit"
                      disabled={submitting}
                      className="w-full gap-2"
                      size="lg"
                    >
                      {submitting
                        ? <><Loader2 className="h-4 w-4 animate-spin" /> Sending...</>
                        : <>Send Message <ArrowRight className="h-4 w-4" /></>
                      }
                    </Button>

                    <p className="text-xs text-center text-muted-foreground">
                      Or{" "}
                      <Link href="https://zentrodesk.com/signup" className="text-primary font-semibold hover:underline">
                        start your free trial directly
                      </Link>{" "}
                      — no credit card needed.
                    </p>
                  </form>
                )}
              </div>
            </div>
          </div>
        </section>
      </main>
      <Footer />
    </div>
  )
}